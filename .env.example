# —— 飞书凭据兜底(优先用 .vega/config.json,即网页里填的那份)——
# 飞书自建应用 app_id / app_secret(开放平台 → 凭证与基础信息)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 开放平台域名:飞书(默认)open.feishu.cn;Lark 国际版 open.larksuite.com
FEISHU_BASE_URL=https://open.feishu.cn

# —— 结构化模型 provider(可换)——
# anthropic = Claude;openai = OpenAI 兼容(智谱 GLM-4V / 通义 Qwen-VL / Gemini / Ollama)
STRUCTURE_PROVIDER=anthropic
# provider=openai 时:base url 与模型(默认智谱)
STRUCTURE_BASE_URL=https://open.bigmodel.cn/api/paas/v4
STRUCTURE_MODEL=glm-4v-flash
# provider=openai 时的 key(智谱在 open.bigmodel.cn 拿)
STRUCTURE_API_KEY=

# —— Anthropic(provider=anthropic 时用)——
ANTHROPIC_API_KEY=
